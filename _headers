# Cloudflare Pages custom headers

# Service Worker — MUST never be cached by CDN or browser
# The browser checks sw.js on every load to detect updates
/sw.js
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache

# Main HTML — never cache so users always get latest version
/
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache

/index.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache

# Manifest — short cache so install prompt stays fresh
/manifest.json
  Cache-Control: no-cache, max-age=0

# Static assets (icons etc.) — can be cached longer
/icons/*
  Cache-Control: public, max-age=86400
